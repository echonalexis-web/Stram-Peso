{
  "info": {
    "_postman_id": "8a5b7796-40d6-4f2f-8aa8-9fbd8e3f6aab",
    "name": "STRAM PESO E2E",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1) Admin Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Admin login success', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Admin token exists', function () { pm.expect(json.token).to.be.a('string').and.not.empty; });",
              "pm.collectionVariables.set('adminToken', json.token);",
              "pm.collectionVariables.set('adminUserId', json.user?.id || json.user?._id || '');"
            ]
          }
        }
      ]
    },
    {
      "name": "2) Generate Invite Code (Admin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/auth/invite"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Invite code generated', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Invite code exists', function () { pm.expect(json.code).to.be.a('string').and.not.empty; });",
              "pm.collectionVariables.set('inviteCode', json.code);"
            ]
          }
        }
      ]
    },
    {
      "name": "3) Register Employer",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{employerName}}\",\n  \"email\": \"{{employerEmail}}\",\n  \"password\": \"{{employerPassword}}\",\n  \"inviteCode\": \"{{inviteCode}}\"\n}"
        },
        "url": "{{baseUrl}}/auth/register/employer"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Employer register success', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });"
            ]
          }
        }
      ]
    },
    {
      "name": "4) Register Resident",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{residentName}}\",\n  \"email\": \"{{residentEmail}}\",\n  \"password\": \"{{residentPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/auth/register"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Resident register success', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
              "const json = pm.response.json();",
              "if (json.token) pm.collectionVariables.set('residentToken', json.token);",
              "if (json.user?.id || json.user?._id) pm.collectionVariables.set('residentUserId', json.user?.id || json.user?._id);"
            ]
          }
        }
      ]
    },
    {
      "name": "5) Employer Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{employerEmail}}\",\n  \"password\": \"{{employerPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Employer login success', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('employerToken', json.token);",
              "pm.collectionVariables.set('employerUserId', json.user?.id || json.user?._id || '');"
            ]
          }
        }
      ]
    },
    {
      "name": "6) Resident Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{residentEmail}}\",\n  \"password\": \"{{residentPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Resident login success', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('residentToken', json.token);",
              "pm.collectionVariables.set('residentUserId', json.user?.id || json.user?._id || '');"
            ]
          }
        }
      ]
    },
    {
      "name": "7) Employer Create Job",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{employerToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"{{jobTitle}}\",\n  \"location\": \"{{jobLocation}}\",\n  \"description\": \"{{jobDescription}}\",\n  \"salary\": \"{{jobSalary}}\",\n  \"jobType\": \"Full-time\",\n  \"requirements\": \"Basic electrical skills\",\n  \"slots\": 1\n}"
        },
        "url": "{{baseUrl}}/employer/jobs"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Create job success', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
              "const json = pm.response.json();",
              "const id = json?._id || json?.job?._id || '';",
              "pm.test('Job id captured', function () { pm.expect(id).to.be.a('string').and.not.empty; });",
              "pm.collectionVariables.set('jobId', id);"
            ]
          }
        }
      ]
    },
    {
      "name": "8) Resident Apply to Job",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{residentToken}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "coverLetter", "value": "I am interested in this role and available immediately.", "type": "text" }
          ]
        },
        "url": "{{baseUrl}}/jobs/{{jobId}}/apply"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Apply success', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
              "const json = pm.response.json();",
              "const appId = json?.application?._id || json?._id || '';",
              "if (appId) pm.collectionVariables.set('applicationId', appId);"
            ]
          }
        }
      ]
    },
    {
      "name": "9) Employer Get Applicants For Job",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{employerToken}}" }
        ],
        "url": "{{baseUrl}}/employer/jobs/{{jobId}}/applicants"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Applicants fetched', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Applicants is array', function () { pm.expect(json).to.be.an('array'); });",
              "if (json.length && json[0]._id) pm.collectionVariables.set('applicationId', json[0]._id);",
              "if (json.length && (json[0].applicant?._id || json[0].applicant?.id)) pm.collectionVariables.set('residentUserId', json[0].applicant?._id || json[0].applicant?.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "10) Employer Update Application Status",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{employerToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"reviewed\",\n  \"employerNote\": \"Thank you, we are reviewing your application.\"\n}"
        },
        "url": "{{baseUrl}}/employer/applications/{{applicationId}}/status"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status updated', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ]
    },
    {
      "name": "11) Employer Create Conversation With Resident",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{employerToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"participantId\": \"{{residentUserId}}\"\n}"
        },
        "url": "{{baseUrl}}/messages/conversations"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Conversation created', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
              "const json = pm.response.json();",
              "const id = json?._id || '';",
              "pm.test('Conversation id captured', function () { pm.expect(id).to.be.a('string').and.not.empty; });",
              "pm.collectionVariables.set('conversationId', id);"
            ]
          }
        }
      ]
    },
    {
      "name": "12) Employer Send Message",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{employerToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"content\": \"Hello from employer E2E test.\"\n}"
        },
        "url": "{{baseUrl}}/messages/conversations/{{conversationId}}/messages"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Message sent', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });"
            ]
          }
        }
      ]
    },
    {
      "name": "13) Resident Get Messages",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{residentToken}}" }
        ],
        "url": "{{baseUrl}}/messages/conversations/{{conversationId}}/messages"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Messages fetched', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Messages array', function () { pm.expect(json).to.be.an('array'); });"
            ]
          }
        }
      ]
    }
